{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RapidML Plugin Pack Manifest",
  "description": "Schema for a distributable plugin pack that bundles methodologies, analysis templates, and concept sets into a single loadable unit. This is a FUTURE extensibility spec — no pack loader is implemented in the current codebase. Today, plugins are added by placing JS files in methodologies/ or templates/ and adding a <script> tag to index.html.",
  "_status": "future",
  "type": "object",
  "required": ["id", "version", "name", "description"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique identifier for this pack (e.g., 'diabetes-nephropathy')"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-z0-9-]+)?$",
      "description": "Semantic version (e.g., '1.0.0')"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name"
    },
    "description": {
      "type": "string",
      "description": "Purpose and scope of this pack"
    },
    "license": {
      "type": "string",
      "enum": ["MIT", "Apache-2.0", "CC0-1.0", "CC-BY-4.0"],
      "description": "License for reuse"
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "institution": { "type": "string" }
        }
      }
    },
    "compatible_with": {
      "type": "object",
      "description": "Version compatibility constraints",
      "properties": {
        "omop_cdm": {
          "type": "string",
          "description": "OMOP CDM version this pack targets (e.g., '5.3', '5.4')"
        }
      }
    },
    "concept_sets": {
      "type": "array",
      "description": "Reusable concept sets defined in this pack",
      "items": {
        "type": "object",
        "required": ["concept_set_id", "name"],
        "properties": {
          "concept_set_id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "concepts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "concept_id": { "type": "integer" },
                "include_descendants": { "type": "boolean", "default": true },
                "exclude": { "type": "boolean", "default": false }
              }
            }
          },
          "research_note": { "type": "string" },
          "provenance": { "type": "string", "description": "Source (e.g., 'OHDSI Phenotype Library', 'institutional derivation')" }
        }
      }
    },
    "cohort_patterns": {
      "type": "array",
      "description": "Named cohort rules (typically used for index/outcome definitions)",
      "items": {
        "type": "object",
        "required": ["pattern_id", "name", "rule"],
        "properties": {
          "pattern_id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "rule": {
            "type": "object",
            "description": "Rule object per study-config.schema.json rule_definition"
          },
          "citations": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "methodologies": {
      "type": "array",
      "description": "Study methodologies provided by this pack",
      "items": {
        "type": "object",
        "required": ["id", "label", "filepath"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "filepath": {
            "type": "string",
            "description": "Relative path to JS file exporting RapidML.Methodologies.register() call"
          },
          "experimental": { "type": "boolean" }
        }
      }
    },
    "analysis_templates": {
      "type": "array",
      "description": "Analysis templates (code generation) provided by this pack",
      "items": {
        "type": "object",
        "required": ["id", "label", "language", "filepath"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "language": {
            "type": "string",
            "enum": ["python", "r", "sql", "java"],
            "description": "Language for output code"
          },
          "filepath": {
            "type": "string",
            "description": "Relative path to JS file exporting RapidML.AnalysisTemplates.register() call"
          },
          "experimental": { "type": "boolean" }
        }
      }
    },
    "examples": {
      "type": "array",
      "description": "Example study configurations demonstrating this pack",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
